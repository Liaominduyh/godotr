; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="知识库"
config/description="本地知识库管理系统 - 人可编辑，AI 可调用"
run/main_scene="uid://dkefddkgra77i"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/EventBus.gd"
KnowledgeBase="*res://scripts/autoload/KnowledgeBase.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"
window/stretch/aspect="ignore"

[gdscript]

gdscript/warnings/enable_all_warnings=true
gdscript/warnings/unsafe_property_access=1
gdscript/warnings/unsafe_cast=1
gdscript/warnings/unsafe_call_argument=1
gdscript/warnings/untyped_declaration=1
